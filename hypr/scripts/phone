#!/bin/bash

echo "--- 📱 Universal Wireless scrcpy ---"

# 1. Get the USB Device ID
USB_DEV=$(adb devices | grep -v "List" | grep "device$" | awk '{print $1}' | head -n 1)

if [ -z "$USB_DEV" ]; then
    echo "❌ No USB device found via 'adb devices'."
    echo "Checking for existing wireless sessions..."
    PHONE_IP=$(adb devices | grep -E '([0-9]{1,3}\.){3}[0-9]{1,3}' | awk '{print $1}' | cut -d: -f1 | head -n 1)
else
    echo "✅ Found USB Device: $USB_DEV"

    # NEW: This searches ALL interfaces (wlan0, eth0, etc.) for a 192.168.x.x IP
    PHONE_IP=$(adb -s "$USB_DEV" shell ip addr show | grep -oE 'inet 192\.168\.[0-9]{1,3}\.[0-9]{1,3}' | awk '{print $2}')

    if [ -z "$PHONE_IP" ]; then
        echo "❌ IP still not found via ADB."
        echo "Trying alternative 'getprop' method..."
        PHONE_IP=$(adb -s "$USB_DEV" shell getprop dhcp.wlan0.ipaddress)
    fi

    if [ -z "$PHONE_IP" ]; then
        echo "⚠️  Could not auto-detect IP. Please type it manually:"
        read PHONE_IP
    fi

    echo "🌐 Using IP: $PHONE_IP"
    adb -s "$USB_DEV" tcpip 5555
    sleep 2
fi

if [ -n "$PHONE_IP" ]; then
    echo "🔗 Connecting to $PHONE_IP..."
    adb connect "$PHONE_IP:5555"
    scrcpy --tcpip="$PHONE_IP:5555" --turn-screen-off --stay-awake
else
    echo "🛑 Failed to find or connect to phone."
fi
